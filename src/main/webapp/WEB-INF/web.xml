<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0" metadata-complete="true">
  <display-name>GURUKUL-ILE</display-name>
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Core Servlets Definition -->
  <servlet>
    <servlet-name>login</servlet-name>
    <servlet-class>com.gurukul.controllers.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>login</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>registration</servlet-name>
    <servlet-class>com.gurukul.controllers.RegistrationServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>registration</servlet-name>
    <url-pattern>/registration</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>logout</servlet-name>
    <servlet-class>com.gurukul.controllers.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>logout</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>userProfile</servlet-name>
    <servlet-class>com.gurukul.controllers.UserProfileServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>userProfile</servlet-name>
    <url-pattern>/userProfile</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>TeacherController</servlet-name>
    <servlet-class>com.gurukul.controllers.TeacherController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>TeacherController</servlet-name>
    <url-pattern>/teacherAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MeetingServlet</servlet-name>
    <servlet-class>com.gurukul.controllers.MeetingServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MeetingServlet</servlet-name>
    <url-pattern>/meetingAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LeaveController</servlet-name>
    <servlet-class>com.gurukul.controllers.LeaveController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LeaveController</servlet-name>
    <url-pattern>/leaveAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ClassController</servlet-name>
    <servlet-class>com.gurukul.controllers.ClassController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ClassController</servlet-name>
    <url-pattern>/classAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AssignmentController</servlet-name>
    <servlet-class>com.gurukul.controllers.AssignmentController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AssignmentController</servlet-name>
    <url-pattern>/assignmentAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AttendanceController</servlet-name>
    <servlet-class>com.gurukul.controllers.AttendanceController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AttendanceController</servlet-name>
    <url-pattern>/attendanceAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>QuizController</servlet-name>
    <servlet-class>com.gurukul.controllers.QuizController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>QuizController</servlet-name>
    <url-pattern>/quizAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ResultController</servlet-name>
    <servlet-class>com.gurukul.controllers.ResultController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ResultController</servlet-name>
    <url-pattern>/resultAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>DownloadTemplateServlet</servlet-name>
    <servlet-class>com.gurukul.controllers.DownloadTemplateServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>DownloadTemplateServlet</servlet-name>
    <url-pattern>/downloadTemplate</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>SubmissionController</servlet-name>
    <servlet-class>com.gurukul.controllers.SubmissionController</servlet-class>
    <multipart-config>
      <max-file-size>10485760</max-file-size>
      <max-request-size>15728640</max-request-size>
      <file-size-threshold>1048576</file-size-threshold>
    </multipart-config>
  </servlet>
  <servlet-mapping>
    <servlet-name>SubmissionController</servlet-name>
    <url-pattern>/submitAction</url-pattern>
  </servlet-mapping>

  <!-- Global Context Parameters -->
  <context-param>
    <param-name>DB_URL</param-name>
    <param-value>10.173.83.231</param-value>
  </context-param>

  <context-param>
    <param-name>DB_USERNAME</param-name>
    <param-value>root</param-value>
  </context-param>

  <context-param>
    <param-name>DB_PWD</param-name>
    <param-value>Admin</param-value>
  </context-param>
  <!-- Trigger reload 2 -->
</web-app>